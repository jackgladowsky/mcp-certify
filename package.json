{
  "name": "mcp-certify",
  "version": "0.1.0",
  "description": "Testing and certification for MCP servers",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jackgladowsky/mcp-certify"
  },
  "homepage": "https://github.com/jackgladowsky/mcp-certify#readme",
  "bugs": {
    "url": "https://github.com/jackgladowsky/mcp-certify/issues"
  },
  "keywords": ["mcp", "model-context-protocol", "testing", "security", "certification"],
  "bin": {
    "mcp-certify": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "prepublishOnly": "npm run build && npm test",
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "vitest run tests/e2e/",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
